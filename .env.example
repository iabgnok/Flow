# 复制为 .env 后填写。勿将含真实密钥的 .env 提交到版本库。
# 变量前缀均为 MYFLOW_，与 src/myflow/infra/config.py 中字段对应。

# MYFLOW_LLM_PROVIDER=anthropic
# MYFLOW_LLM_PROVIDER=openai
# MYFLOW_LLM_PROVIDER=deepseek

# MYFLOW_LLM_MODEL=claude-sonnet-4-20250514
# MYFLOW_LLM_MODEL=gpt-4o
# MYFLOW_LLM_MODEL=deepseek-chat

# MYFLOW_LLM_API_KEY=

# 可选：OpenAI 兼容网关（DeepSeek 不写则默认 https://api.deepseek.com）
# MYFLOW_LLM_BASE_URL=

# MYFLOW_LLM_TEMPERATURE=0.3

# MYFLOW_WORKFLOWS_DIR=workflows
# MYFLOW_DB_PATH=myflow_state.db

# 设为 1 时运行 tests/integration/test_llm_live.py 会请求真实 API（计费）
# MYFLOW_RUN_LLM_TESTS=1
